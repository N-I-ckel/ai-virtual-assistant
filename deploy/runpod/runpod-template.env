# Runpod Environment Configuration Template
# Copy this file to .env and fill in your API keys

# Required: NVIDIA API Keys
# Get from: https://build.nvidia.com/ or https://ngc.nvidia.com/
NVIDIA_API_KEY="your-nvidia-api-key-here"
NGC_API_KEY="your-ngc-api-key-here"

# LLM Model Configuration
# For Runpod with limited GPU, you might want to use smaller models
# Options: meta/llama-3.3-70b-instruct, meta/llama3-8b-instruct, etc.
APP_LLM_MODELNAME="meta/llama-3.3-70b-instruct"

# If you want to use local NIMs on Runpod (requires more GPU memory)
# Uncomment and configure these:
# USE_LOCAL_NIMS=true
# APP_LLM_SERVERURL="localhost:8000"
# APP_EMBEDDINGS_SERVERURL="localhost:9080"
# APP_RANKING_SERVERURL="localhost:1976"

# Database Configuration (can keep defaults)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=securepassword123
POSTGRES_DB=postgres
CUSTOMER_DATA_DB=customer_data

# PGAdmin Configuration (optional)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin123

# Redis Configuration
REDIS_SESSION_EXPIRY=12

# Logging Level
LOGLEVEL=INFO

# GPU Configuration for Runpod
# Adjust based on your Runpod instance
VECTORSTORE_GPU_DEVICE_ID=0
LLM_MS_GPU_ID=0,1
EMBEDDING_MS_GPU_ID=2
RANKING_MS_GPU_ID=3